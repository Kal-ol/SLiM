function (numeric) getPhenotype(object<Individual> ind)
{
    g = ind.genomes;

    n_m5 = size(g.mutationsOfType(m5));
    n_m6 = size(g.mutationsOfType(m6));

    total = n_m5 + n_m6;

    if (total == 0)
        return 0.5;

    return n_m6 / total;
}



function (numeric) bdmiMultiplier(object<Individual> ind)
{
    g = ind.genomes;

    n_m1 = size(g.mutationsOfType(m1));
    n_m2 = size(g.mutationsOfType(m2));

    n_pairs = min(n_m1, n_m2);

    if (n_pairs == 0)
        return 1.0;

    return (1.0 - sb)^n_pairs;
}




function (numeric) densityFecundity(integer N)
{
    return dd_rate0 / (1.0 + alpha * N);
}



initialize()
{
    initializeSLiMModelType("nonWF");



    if (!exists("K_p1"))
        defineConstant("K_p1", 500);

    if (!exists("K_p2"))
        defineConstant("K_p2", 500);

    if (!exists("K_p3"))
        defineConstant("K_p3", 500);

    if (!exists("burnin"))
        defineConstant("burnin", 2000);

    if (!exists("endGen"))
        defineConstant("endGen", 3000);

    if (!exists("L"))
        defineConstant("L", 100000);

    if (!exists("mu"))
        defineConstant("mu", 1e-8);

    if (!exists("recomb"))
        defineConstant("recomb", 1e-8);

    if (!exists("alpha"))
        defineConstant("alpha", 0.005);

    // Increased for annual stability
    if (!exists("dd_rate0"))
        defineConstant("dd_rate0", 5.0);

    if (!exists("maxOvules"))
        defineConstant("maxOvules", 5);

    if (!exists("hybRate"))
        defineConstant("hybRate", 0.05);

    if (!exists("sb"))
        defineConstant("sb", 0.25);

    if (!exists("sAdapt"))
        defineConstant("sAdapt", 0.01);

    if (!exists("pBDMI"))
        defineConstant("pBDMI", 0.01);

    if (!exists("pAdapt"))
        defineConstant("pAdapt", 0.01);

    if (!exists("traitSigma"))
        defineConstant("traitSigma", 0.30);



    initializeMutationRate(mu);
    initializeRecombinationRate(recomb);

    // m1: P1-derived BDMI allele
    // m2: P2-derived BDMI allele
    // m5: P1-adaptive allele
    // m6: P2-adaptive allele
    // m7: neutral background mutation type

    initializeMutationType("m1", 0.5, "f", 0.0);
    initializeMutationType("m2", 0.5, "f", 0.0);
    initializeMutationType("m5", 0.5, "f", 0.0);
    initializeMutationType("m6", 0.5, "f", 0.0);
    initializeMutationType("m7", 0.5, "f", 0.0);

    m1.convertToSubstitution = F;
    m2.convertToSubstitution = F;
    m5.convertToSubstitution = F;
    m6.convertToSubstitution = F;
    m7.convertToSubstitution = T;

    initializeGenomicElementType("g1", m7, 1.0);
    initializeGenomicElement(g1, 0, L - 1);
}




1 early()
{
    sim.addSubpop("p1", K_p1);
    sim.addSubpop("p2", K_p2);
    sim.addSubpop("p3", 0);

    catn("Generation,Phase,N_p1,N_p2,N_p3,MeanPhen_p1,MeanPhen_p2,MeanPhen_p3");
}




early()
{
    if (community.tick <= burnin)
    {
        // P1 accumulates m1 BDMIs and m5 adaptive mutations
        for (ind in p1.individuals)
        {
            if (runif(1) < pBDMI)
            {
                pos = rdunif(1, 0, L - 1);
                ind.genome1.addNewDrawnMutation(m1, pos);
            }

            if (runif(1) < pAdapt)
            {
                pos = rdunif(1, 0, L - 1);
                ind.genome1.addNewDrawnMutation(m5, pos);
            }
        }

        // P2 accumulates m2 BDMIs and m6 adaptive mutations
        for (ind in p2.individuals)
        {
            if (runif(1) < pBDMI)
            {
                pos = rdunif(1, 0, L - 1);
                ind.genome1.addNewDrawnMutation(m2, pos);
            }

            if (runif(1) < pAdapt)
            {
                pos = rdunif(1, 0, L - 1);
                ind.genome1.addNewDrawnMutation(m6, pos);
            }
        }
    }
}



reproduction()
{
    pop = individual.subpopulation;

    Nlocal = pop.individualCount;
    fertRate = densityFecundity(Nlocal);

    nOff = rpois(1, maxOvules * fertRate);

    if (nOff <= 0)
        return;

    for (i in seqLen(nOff))
    {
        mate = NULL;
        offspringPop = pop;


        if (community.tick <= burnin)
        {
            if (pop.individualCount > 1)
                mate = pop.sampleIndividuals(1, exclude=individual);
        }


        else
        {
            if (pop == p1)
            {
                if ((runif(1) < hybRate) & (p2.individualCount > 0))
                {
                    mate = p2.sampleIndividuals(1);
                    offspringPop = p3;
                }
                else if (p1.individualCount > 1)
                {
                    mate = p1.sampleIndividuals(1, exclude=individual);
                    offspringPop = p1;
                }
            }

            else if (pop == p2)
            {
                if ((runif(1) < hybRate) & (p1.individualCount > 0))
                {
                    mate = p1.sampleIndividuals(1);
                    offspringPop = p3;
                }
                else if (p2.individualCount > 1)
                {
                    mate = p2.sampleIndividuals(1, exclude=individual);
                    offspringPop = p2;
                }
            }

            else if (pop == p3)
            {
                if (p3.individualCount > 1)
                {
                    mate = p3.sampleIndividuals(1, exclude=individual);
                    offspringPop = p3;
                }
            }
        }

        // Correct SLiM/Eidos NULL test
        if (!isNULL(mate))
        {
            offspringPop.addCrossed(individual, mate);
        }
    }
}



early()
{
    // Apply viability only to newborns
    inds = sim.subpopulations.individuals;
    newborns = inds[inds.age == 0];

    if (size(newborns) > 0)
    {
        for (ind in newborns)
        {
            bdmiFit = bdmiMultiplier(ind);
            phen = getPhenotype(ind);

            // Environment-specific stabilizing selection
            // During burn-in:
            //   P1 optimum = 0
            //   P2 optimum = 1
            // After secondary contact:
            //   P3 optimum = 0.5

            if (ind.subpopulation == p1)
                opt = 0.0;
            else if (ind.subpopulation == p2)
                opt = 1.0;
            else
                opt = 0.5;

            traitFit = exp(-((phen - opt)^2) / (2.0 * traitSigma^2));

            totalFit = bdmiFit * traitFit;

            if (runif(1) > totalFit)
                ind.fitnessScaling = 0.0;
        }
    }
}




late()
{
    // In annual model, individuals older than newborns die.
    // This creates non-overlapping generations.

    adults = sim.subpopulations.individuals[sim.subpopulations.individuals.age > 0];

    if (size(adults) > 0)
        adults.fitnessScaling = 0.0;
}



late()
{
    phen1 = 0.0;
    phen2 = 0.0;
    phen3 = 0.0;

    if (p1.individualCount > 0)
        phen1 = mean(sapply(p1.individuals, "getPhenotype(applyValue);"));

    if (p2.individualCount > 0)
        phen2 = mean(sapply(p2.individuals, "getPhenotype(applyValue);"));

    if (p3.individualCount > 0)
        phen3 = mean(sapply(p3.individuals, "getPhenotype(applyValue);"));

    if (community.tick <= burnin)
        phase = "burnin";
    else
        phase = "postBurnin";

    catn(community.tick + "," +
         phase + "," +
         p1.individualCount + "," +
         p2.individualCount + "," +
         p3.individualCount + "," +
         phen1 + "," +
         phen2 + "," +
         phen3);
}



endGen late()
{
    catn("Simulation finished.");
    sim.simulationFinished();
}

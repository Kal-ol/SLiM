// competetion

function (numeric) localPhenotypicDensity(object<Individual> focal, object<Individual> competitors)
{
    focalZ = getPhenotype(focal);

    Nlocal = 0.0;

    if (size(competitors) == 0)
        return Nlocal;

    for (other in competitors)
    {
        if (other == focal)
            next;

        otherZ = getPhenotype(other);

        d2 = phenDistance2(focalZ, otherZ);

        compWeight = exp(-d2 / (2.0 * compSigma^2));

        Nlocal = Nlocal + compWeight;
    }

    return Nlocal;
}


// dens-dep. fecundity

function (numeric) densityFecundity(numeric Nlocal)
{
    return dd_rate0 / (1.0 + alpha * Nlocal);
}


// assort. mating

function (object<Individual>$) chooseMateByPhenotype(object<Individual> focal, object<Individual> candidates)
{
    if (size(candidates) == 0)
        return NULL;

    candidates = candidates[candidates != focal];

    if (size(candidates) == 0)
        return NULL;

    candidates = candidates[candidates.tag == 1];

    if (size(candidates) == 0)
        return NULL;

    focalZ = getPhenotype(focal);

    weights = c();

    for (cand in candidates)
    {
        candZ = getPhenotype(cand);

        d2 = phenDistance2(focalZ, candZ);

        w = exp(-d2 / (2.0 * mateSigma^2)) + epsilonMate;

        weights = c(weights, w);
    }

    return sample(candidates, 1, weights=weights);
}


//mean pheno

function (numeric) meanPhenotype(object<Individual> inds)
{
    if (size(inds) == 0)
        return c(0.0, 0.0);

    z1vals = c();
    z2vals = c();

    for (ind in inds)
    {
        Z = getPhenotype(ind);
        z1vals = c(z1vals, Z[0]);
        z2vals = c(z2vals, Z[1]);
    }

    return c(mean(z1vals), mean(z2vals));
}


// surv prob.

function (numeric) preReproSurvival(object<Individual> ind)
{
    bdmiFit = bdmiMultiplier(ind);
    Z = getPhenotype(ind);

    theta1 = c(theta1_z1, theta1_z2);
    theta2 = c(theta2_z1, theta2_z2);
    thetaH = c(thetaH_z1, thetaH_z2);

    // ------------------------------------------------------------
    // During burn-in:
    //      p1 is selected toward theta1
    //      p2 is selected toward theta2
    // ------------------------------------------------------------

    if (community.tick <= burnin)
    {
        if (ind.subpopulation == p1)
            theta = theta1;
        else if (ind.subpopulation == p2)
            theta = theta2;
        else
            theta = thetaH;

        traitFit = traitFitness2D(Z, theta);
    }


    else
    {
        if (envScenario == "neutral")
        {
            traitFit = 1.0;
        }

        else if (envScenario == "theta1")
        {
            theta = theta1;
            traitFit = traitFitness2D(Z, theta);
        }

        else if (envScenario == "theta2")
        {
            theta = theta2;
            traitFit = traitFitness2D(Z, theta);
        }

        else if (envScenario == "twohab")
        {
            if (ind.subpopulation == p1)
                theta = theta1;
            else if (ind.subpopulation == p2)
                theta = theta2;
            else
                theta = thetaH;

            traitFit = traitFitness2D(Z, theta);
        }

        else
        {
            stop("Unknown envScenario. Use neutral, theta1, theta2, or twohab.");
        }
    }

    totalFit = bdmiFit * traitFit;

    if (totalFit < 0.0)
        totalFit = 0.0;

    if (totalFit > 1.0)
        totalFit = 1.0;

    return totalFit;
}


initialize()
{
    initializeSLiMModelType("nonWF");

    // Turn on tree-sequence recording
    initializeTreeSeq();


    if (!exists("K_p1"))
        defineConstant("K_p1", 200);

    if (!exists("K_p2"))
        defineConstant("K_p2", 200);

    if (!exists("K_p3"))
        defineConstant("K_p3", 200);

    if (!exists("burnin"))
        defineConstant("burnin", 2000);

    if (!exists("endGen"))
        defineConstant("endGen", 5000);

    if (!exists("L"))
        defineConstant("L", 100000);


    if (!exists("phenoStart"))
        defineConstant("phenoStart", 0);

    if (!exists("phenoEnd"))
        defineConstant("phenoEnd", asInteger(floor(L / 3.0)) - 1);

    if (!exists("bdmiStart"))
        defineConstant("bdmiStart", phenoEnd + 1);

    if (!exists("bdmiEnd"))
        defineConstant("bdmiEnd", asInteger(floor(2.0 * L / 3.0)) - 1);

    if (!exists("neutralStart"))
        defineConstant("neutralStart", bdmiEnd + 1);

    if (!exists("neutralEnd"))
        defineConstant("neutralEnd", L - 1);

    if (!exists("muNeutral"))
        defineConstant("muNeutral", 0);

    if (!exists("mupheno"))
        defineConstant("mupheno", 1e-5);

    if (!exists("muBDMI"))
        defineConstant("muBDMI", 1e-5);

    if (!exists("recomb"))
        defineConstant("recomb", 1e-8);


    if (!exists("alpha"))
        defineConstant("alpha", 0.005);

    if (!exists("dd_rate0"))
        defineConstant("dd_rate0", 0.5);

    if (!exists("maxOvules"))
        defineConstant("maxOvules", 5);


    if (!exists("hybRate"))
        defineConstant("hybRate", 0.05);

    if (!exists("sb"))
        defineConstant("sb", 0.25);

    if (!exists("addNeutralForward"))
        defineConstant("addNeutralForward", F);

    defineConstant("phenoRegionLength", phenoEnd - phenoStart + 1);
    defineConstant("bdmiRegionLength", bdmiEnd - bdmiStart + 1);
    defineConstant("neutralRegionLength", neutralEnd - neutralStart + 1);

    // BDMI accumulation mode:
    //   "burnin"     = accept new BDMI mutations only during burn-in
    //   "continuous" = accept new BDMI mutations in parental populations during burn-in and post-burn-in
    if (!exists("bdmiAccumulation"))
        defineConstant("bdmiAccumulation", "burnin");

    if ((bdmiAccumulation != "burnin") & (bdmiAccumulation != "continuous"))
        stop("Unknown bdmiAccumulation. Use 'burnin' or 'continuous'.");

    // Neutral mutations are optional.
    // If addNeutralForward=F, the neutral-region mutation rate is set to 0.
    if (addNeutralForward)
        defineConstant("muNeutralUsed", muNeutral);
    else
        defineConstant("muNeutralUsed", 0.0);

    // Total proposed mutation input across regions.
    // In the BDMI region, the total proposal rate is 2*muBDMI because
    // m1 and m2 each have class-specific rate muBDMI.
    defineConstant("muTotal", mupheno + 2.0 * muBDMI + muNeutralUsed);


    if (!exists("phenoLambda"))
        defineConstant("phenoLambda", 0.02);



    if (!exists("theta1_z1"))
        defineConstant("theta1_z1", 1.2);

    if (!exists("theta1_z2"))
        defineConstant("theta1_z2", 1.5);

    if (!exists("theta2_z1"))
        defineConstant("theta2_z1", 3.5);

    if (!exists("theta2_z2"))
        defineConstant("theta2_z2", 3.0);


    if (!exists("ancestral_z1"))
        defineConstant("ancestral_z1", (theta1_z1 + theta2_z1) / 2.0);

    if (!exists("ancestral_z2"))
        defineConstant("ancestral_z2", (theta1_z2 + theta2_z2) / 2.0);

    // Hybrid/neutral reference optima also default to the midpoint.
    if (!exists("thetaH_z1"))
        defineConstant("thetaH_z1", ancestral_z1);

    if (!exists("thetaH_z2"))
        defineConstant("thetaH_z2", ancestral_z2);

    if (!exists("thetaN_z1"))
        defineConstant("thetaN_z1", ancestral_z1);

    if (!exists("thetaN_z2"))
        defineConstant("thetaN_z2", ancestral_z2);

    if (!exists("traitSigma"))
        defineConstant("traitSigma", 1.50);

    if (!exists("compSigma"))
        defineConstant("compSigma", 0.30);

    if (!exists("mateSigma"))
        defineConstant("mateSigma", 0.30);

    if (!exists("epsilonMate"))
        defineConstant("epsilonMate", 1e-6);

    // Post-burn-in environmental scenario

    if (!exists("envScenario"))
        defineConstant("envScenario", "neutral");

    // Output files.
    // outputFile stores the per-generation CSV-style results.
    // treeSeqFile stores the final tree-sequence output at endGen.
    // burninTreeSeqFile stores the burn-in checkpoint at burnin.
    // rememberEvery controls how often living individuals are permanently remembered
    // in the tree sequence. With rememberEvery=100, samples are remembered at
    // ticks 1, 100, 200, ..., endGen.
    // These files are written to the folder where you run SLiM.
    if (!exists("outputFile"))
        defineConstant("outputFile", "output.txt");

    if (!exists("treeSeqFile"))
        defineConstant("treeSeqFile", "pheno_2d_model_final.trees");

    if (!exists("burninTreeSeqFile"))
        defineConstant("burninTreeSeqFile", "pheno_2d_model_burnin_tick2000.trees");

    if (!exists("rememberEvery"))
        defineConstant("rememberEvery", 100);


    // Strict SLiM mutation process with region-specific mutation rates:
    //   pheno region     : mupheno
    //   BDMI region    : 2*muBDMI total, split equally between m1 and m2
    //   Neutral region : muNeutralUsed
    initializeMutationRate(c(mupheno, 2.0 * muBDMI, muNeutralUsed),
                           c(phenoEnd, bdmiEnd, neutralEnd));

    initializeRecombinationRate(recomb);

    initializeMutationType("m1", 0.5, "f", 0.0);
    initializeMutationType("m2", 0.5, "f", 0.0);
    initializeMutationType("m3", 0.5, "f", 0.0);
    initializeMutationType("m7", 0.5, "f", 0.0);

    m1.convertToSubstitution = F;
    m2.convertToSubstitution = F;
    m3.convertToSubstitution = F;
    m7.convertToSubstitution = F;

    initializeGenomicElementType("g1", m3, 1.0);
    initializeGenomicElementType("g2", c(m1, m2), c(1.0, 1.0));
    initializeGenomicElementType("g3", m7, 1.0);

    initializeGenomicElement(g1, phenoStart, phenoEnd);
    initializeGenomicElement(g2, bdmiStart, bdmiEnd);
    initializeGenomicElement(g3, neutralStart, neutralEnd);
}


// ------------------------------------------------------------
// Mutation callbacks
// ------------------------------------------------------------
// These callbacks keep the model in a strict SLiM mutation-rate framework
// while preserving the biological meaning of parent-specific BDMIs.

// pheno mutations can arise anywhere in the pheno region.
// Assign each new pheno mutation a 2D phenotypic effect.
mutation(m3)
{
    setphenoEffect(mut);
    return T;
}


// p1-type BDMI mutations.
// These are accepted only in p1.
// If bdmiAccumulation == "burnin", they are accepted only during burn-in.
// If bdmiAccumulation == "continuous", they continue to accumulate in p1 after burn-in.
mutation(m1)
{
    if (subpop != p1)
        return F;

    if (bdmiAccumulation == "burnin")
    {
        if (community.tick <= burnin)
            return T;
        else
            return F;
    }

    // continuous mode
    return T;
}


// p2-type BDMI mutations.
// These are accepted only in p2.
// If bdmiAccumulation == "burnin", they are accepted only during burn-in.
// If bdmiAccumulation == "continuous", they continue to accumulate in p2 after burn-in.
mutation(m2)
{
    if (subpop != p2)
        return F;

    if (bdmiAccumulation == "burnin")
    {
        if (community.tick <= burnin)
            return T;
        else
            return F;
    }

    // continuous mode
    return T;
}


// Neutral mutations are accepted when addNeutralForward is enabled.
// If addNeutralForward=F, muNeutralUsed is already 0, so this should rarely be called.
mutation(m7)
{
    return addNeutralForward;
}



1 early()
{
    sim.addSubpop("p1", K_p1);
    sim.addSubpop("p2", K_p2);
    sim.addSubpop("p3", 0);

    header = "Generation,Phase,EnvScenario,N_p1,N_p2,N_p3,MeanZ1_p1,MeanZ2_p1,MeanZ1_p2,MeanZ2_p2,MeanZ1_p3,MeanZ2_p3";
    writeFile(outputFile, header, append=F);

    catn("Writing per-generation output to: " + outputFile);
}


early()
{
    inds = sim.subpopulations.individuals;

    if (size(inds) > 0)
    {
        for (ind in inds)
        {
            survProb = preReproSurvival(ind);

            if (runif(1) <= survProb)
                ind.tag = 1;
            else
                ind.tag = 0;
        }
    }
}



reproduction()
{
    pop = individual.subpopulation;

    if (individual.tag == 0)
        return;

    if (community.tick <= burnin)
        competitors = pop.individuals[pop.individuals.tag == 1];
    else
        competitors = sim.subpopulations.individuals[sim.subpopulations.individuals.tag == 1];

    Nlocal = localPhenotypicDensity(individual, competitors);

    fertRate = densityFecundity(Nlocal);

    nOff = rbinom(1, maxOvules, fertRate);

    if (nOff <= 0)
        return;

    for (i in seqLen(nOff))
    {
        mate = NULL;
        offspringPop = pop;

        if (community.tick <= burnin)
        {
            mate = chooseMateByPhenotype(individual, pop.individuals);
            offspringPop = pop;
        }


        else
        {
		p2Survivors = p2.individuals[p2.individuals.tag == 1];
            if (pop == p1)
            {
                if ((runif(1) < hybRate) & (p2.individualCount > 0))
                {
                    mate = chooseMateByPhenotype(individual, p2.individuals);
                    offspringPop = p3;
                }
                else
                {
                    mate = chooseMateByPhenotype(individual, p1.individuals);
                    offspringPop = p1;
                }
            }

		
            else if (pop == p2)
            {
		p2Survivors = p1.individuals[p1.individuals.tag == 1];
                if ((runif(1) < hybRate) & (p1.individualCount > 0))
                {
                    mate = chooseMateByPhenotype(individual, p1.individuals);
                    offspringPop = p3;
                }
                else
                {
                    mate = chooseMateByPhenotype(individual, p2.individuals);
                    offspringPop = p2;
                }
            }

            else if (pop == p3)
            {
                mate = chooseMateByPhenotype(individual, p3.individuals);
                offspringPop = p3;
            }
        }

        if (!isNULL(mate))
        {
            child = offspringPop.addCrossed(individual, mate);

            // Mutations are generated automatically by SLiM's mutation process.
            // pheno effects and BDMI lineage restrictions are handled in mutation() callbacks.
        }
    }
}



late()
{
    // Adults die after reproduction.
    // Newborns remain and become the next generation.

    adults = sim.subpopulations.individuals[sim.subpopulations.individuals.age > 0];

    if (size(adults) > 0)
        sim.killIndividuals(adults);
}


late()
{
    meanP1 = meanPhenotype(p1.individuals);
    meanP2 = meanPhenotype(p2.individuals);
    meanP3 = meanPhenotype(p3.individuals);

    if (community.tick <= burnin)
        phase = "burnin";
    else
        phase = "postBurnin";

    outLine = community.tick + "," +
              phase + "," +
              envScenario + "," +
              p1.individualCount + "," +
              p2.individualCount + "," +
              p3.individualCount + "," +
              meanP1[0] + "," +
              meanP1[1] + "," +
              meanP2[0] + "," +
              meanP2[1] + "," +
              meanP3[0] + "," +
              meanP3[1];

    writeFile(outputFile, outLine, append=T);
}




late()
{
    // Remember all living individuals at ticks:
    //   1, 100, 200, ..., endGen
    // The final tree sequence will contain these remembered time points.
    shouldRemember = (community.tick == 1) |
                     ((community.tick % rememberEvery) == 0) |
                     (community.tick == endGen);

    if (shouldRemember)
    {
        if (p1.individualCount > 0)
            sim.treeSeqRememberIndividuals(p1.individuals, permanent=T);

        if (p2.individualCount > 0)
            sim.treeSeqRememberIndividuals(p2.individuals, permanent=T);

        if (p3.individualCount > 0)
            sim.treeSeqRememberIndividuals(p3.individuals, permanent=T);

        catn("Remembered all living individuals at tick " + community.tick +
             ": N_p1=" + p1.individualCount +
             ", N_p2=" + p2.individualCount +
             ", N_p3=" + p3.individualCount);
    }

    // Write one burn-in tree sequence exactly at the end of burn-in.
    // For burnin=2000 and rememberEvery=100, this contains samples from
    // ticks 1, 100, 200, ..., 2000.
    if (community.tick == burnin)
    {
        sim.treeSeqOutput(burninTreeSeqFile);
        catn("Burn-in tree sequence saved to: " + burninTreeSeqFile);
    }
}


endGen late()
{
    // Write the final tree sequence at endGen.
    // For endGen=5000 and rememberEvery=100, this contains samples from
    // ticks 1, 100, 200, ..., 5000.
    sim.treeSeqOutput(treeSeqFile);

    catn("Final counts: N_p1=" + p1.individualCount +
     ", N_p2=" + p2.individualCount +
     ", N_p3=" + p3.individualCount);

    catn("Simulation finished.");
    catn("Per-generation output saved to: " + outputFile);
    catn("Tree sequence saved to: " + treeSeqFile);
    sim.simulationFinished();
}

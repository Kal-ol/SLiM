// phenotype function

function (numeric) getPhenotype(object<Individual> ind)
{
    // Individuals begin at the ancestral phenotype, placed midway between the two parental environmental optima
    Z = c(ancestral_z1, ancestral_z2);

    phenoMuts = ind.genomes.mutationsOfType(m3);

    if (size(phenoMuts) == 0)
        return Z;

    for (mut in phenoMuts)
    {
        Z = Z + mut.getValue("deltaZ");
    }

    return Z;
}


// square distance between the phenotype

function (numeric) phenDistance2(numeric Z1, numeric Z2)
{
    dz1 = Z1[0] - Z2[0];
    dz2 = Z1[1] - Z2[1];

    return dz1^2 + dz2^2;
}


//2D gaussian function for trait based fitness

function (numeric) traitFitness2D(numeric Z, numeric theta)
{
    d2 = phenDistance2(Z, theta);

    return exp(-d2 / (2.0 * traitSigma^2));
}


// BDMI fitness
// n_pair gives us the minimum number of BDMI pairs
// sb gives us sleection coefficient for BDMI mut

function (numeric) bdmiMultiplier(object<Individual> ind)
{
    g = ind.genomes;

    n_m1 = size(g.mutationsOfType(m1));
    n_m2 = size(g.mutationsOfType(m2));

    n_pairs = min(n_m1, n_m2);

    if (n_pairs == 0)
        return 1.0;

    return (1.0 - sb)^n_pairs;
}


// effect vector - to - phenotype mutation

function (void) setphenoEffect(object<Mutation> phenoMut)
{
    normalDraw = rnorm(2);
    normLength = sqrt(sum(normalDraw^2));

    if (normLength == 0.0)
        normalDraw = c(1.0, 0.0);
    else
        normalDraw = normalDraw / normLength;

    effectSize = rexp(1, mu=phenoLambda);

    deltaZ = normalDraw * effectSize;

    phenoMut.setValue("deltaZ", deltaZ);
}


// genomic region - to - mutation

function (integer) drawphenoPosition(void)
{
    return rdunif(1,phenoStart, phenoEnd);
}

function (integer) drawBDMIPosition(void)
{
    return rdunif(1, bdmiStart, bdmiEnd);
}

function (integer) drawNeutralPosition(void)
{
    return rdunif(1, neutralStart, neutralEnd);
}


// mut additon

function (void) addNewbornMutationsToChild(object<Individual> child, object<Subpopulation> offspringPop)
{
    // No-op in the strict mutation-rate version.
    // Mutations are now generated by SLiM through initializeMutationRate().
    // pheno effects and lineage-specific BDMI filtering are handled by mutation() callbacks.
